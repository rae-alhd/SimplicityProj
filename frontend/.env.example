# Task Q1.1: safe placeholder only — never copy a real deployed URL or
# secret into this file. Copy this to frontend/.env.local (or set the
# equivalent variable on Vercel) and fill in your real deployed backend's
# API base URL, including the /api path segment.
#
# Required for `npm run build` (a production build). The build fails fast
# with a clear error — "VITE_API_URL is required for a production build."
# — if this is missing, blank, or not a valid http(s) URL with a base path
# (see frontend/src/config/validateApiUrl.js for the exact rules: no
# javascript:/data:/ftp: schemes, no embedded username/password, no query
# string or fragment, no bare origin without a path).
#
# Local `npm run dev` does not need this at all — it conveniently defaults
# to http://localhost:5000/api on its own (see frontend/src/config/api.js).
VITE_API_URL=https://your-backend-name.onrender.com/api
