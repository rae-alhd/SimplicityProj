# Task P1: safe placeholders only — never copy real values into this file.
# Copy this to backend/.env and fill in your own local values.

# Standard app configuration
PORT=5000
NODE_ENV=development

# Real development/production database. Never used by the test suite.
DATABASE_URL=postgresql://username:password@localhost:5432/simplicity_db

# Separate, isolated database for the automated test suite. Must be a
# distinct database from DATABASE_URL, and its name must contain "test" or
# "testing" — backend/src/config/testDbGuard.js refuses to run against
# anything else. See the README's Testing section for how to create this
# database locally.
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/simplicity_test_db

# Auth. In production, JWT_SECRET must be a real random secret — startup
# validation (backend/src/config/envValidation.js) refuses to boot with
# NODE_ENV=production if it's missing, a placeholder, or under 32
# characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1h

# CORS: the deployed frontend origin(s) allowed to call this API. Required
# in production (startup validation refuses to boot without at least one
# of FRONTEND_URL / ALLOWED_ORIGINS set) — see backend/src/config/cors.js.
# Local development origins (http://localhost:5173) are always allowed
# automatically and don't need to be listed here.
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated list, if more than one frontend origin needs
# access (e.g. a preview deployment alongside production). Takes priority
# over FRONTEND_URL when set.
# ALLOWED_ORIGINS=https://simplicity.example.com,https://simplicity-preview.example.com

# Optional: this backend's own public URL, used to build absolute
# uploaded-image URLs (product photos, homepage/design images). Falls back
# to detecting the URL from the incoming request if unset — but pinning it
# explicitly is the safest, most predictable option in production.
# BACKEND_PUBLIC_URL=https://your-backend-name.onrender.com
