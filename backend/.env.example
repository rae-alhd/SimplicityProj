# Task P1: safe placeholders only — never copy real values into this file.
# Copy this to backend/.env and fill in your own local values.

# Standard app configuration
PORT=5000
NODE_ENV=development

# Real development/production database. Never used by the test suite.
DATABASE_URL=postgresql://username:password@localhost:5432/simplicity_db

# Separate, isolated database for the automated test suite. Must be a
# distinct database from DATABASE_URL, and its name must contain "test" or
# "testing" — backend/src/config/testDbGuard.js refuses to run against
# anything else. See the README's Testing section for how to create this
# database locally.
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/simplicity_test_db

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1h

# Frontend origin, if/when CORS is restricted to a specific origin instead
# of the current allow-all default (kept here for forward compatibility —
# not currently read by any code).
# FRONTEND_URL=http://localhost:5173
